# ==============================================================================
# .env.example - Environment Variables Template
# 
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to GitHub
# ==============================================================================

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
MONGODB_URI=mongodb://localhost:27017/mercy-city

# ==============================================================================
# JWT AUTHENTICATION
# ==============================================================================
# Change JWT_SECRET to a strong random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ==============================================================================
# TWILIO SMS SERVICE
# ==============================================================================
# Get these from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=AC035538b950766b9c6e6ee9d2b06b6b8f
TWILIO_AUTH_TOKEN=d6facc34f2717117c20c243cfa3aaab5
TWILIO_PHONE_NUMBER=+263719281211

# ==============================================================================
# TWILIO VERIFY SERVICE (for OTP)
# ==============================================================================
# Create a Verify Service in Twilio Console
# Get the Service SID from: https://www.twilio.com/console/verify/services
TWILIO_VERIFY_SID=VA_YOUR_VERIFY_SERVICE_SID

# ==============================================================================
# EMAIL CONFIGURATION (SMTP)
# ==============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# ==============================================================================
# SENTRY_DSN=https://your-sentry-url
# GOOGLE_ANALYTICS_ID=G_YOUR_ID

# ==============================================================================
# NOTES:
# ==============================================================================
# 1. For production, always use strong, randomly generated values
# 2. Store secrets in a secure vault (e.g., AWS Secrets Manager)
# 3. Rotate JWT_SECRET periodically
# 4. Never expose these values in client-side code
# 5. Use different values for development, staging, and production
